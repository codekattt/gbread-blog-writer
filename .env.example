GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
CAPTURE_WORKER_URL=http://127.0.0.1:4100
CAPTURE_WORKER_TOKEN=your_capture_worker_token

# Daily Discord/Tistory blog bot
VERCEL_APP_URL=https://your-vercel-app.vercel.app
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_COOKIES_HEADER=VISITOR_INFO1_LIVE=...; LOGIN_INFO=...
FORCE_RUN=0
KOREA_HOLIDAY_FAIL_OPEN=0

# Optional: Tistory private publishing. Keep visibility=0 until tested.
TISTORY_ACCESS_TOKEN=your_tistory_access_token
TISTORY_BLOG_NAME=your_blog_name
TISTORY_CATEGORY_ID=
TISTORY_VISIBILITY=0
TISTORY_ACCEPT_COMMENT=0
